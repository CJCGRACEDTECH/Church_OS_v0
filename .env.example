# Church OS — environment variables template
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/churchos

# Secret used to sign session cookies (required, min 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string

# Server port (optional, defaults to 8080)
PORT=8080

# Node environment: development | production | test
NODE_ENV=development

# Self-service signup target church slug.
# Keep this aligned with an existing churches.slug value.
DEFAULT_SIGNUP_CHURCH_SLUG=cjc-international

# Frontend destination after successful OAuth callback.
APP_BASE_URL=http://localhost:5173

# Admin invitation links expire after this many hours.
ADMIN_INVITE_TTL_HOURS=72

# Optional transactional email provider for admin invites.
# If RESEND_API_KEY is omitted, invite links are logged by the API server for local/Replit testing.
RESEND_API_KEY=
INVITE_EMAIL_FROM="Church OS <no-reply@example.com>"

# Stripe Giving
# Use Stripe-hosted Checkout/Billing. Do not store card data in Church OS.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional for future Stripe.js/client-side enhancements. Current v0 redirects through backend-created Checkout Sessions.
VITE_STRIPE_PUBLISHABLE_KEY=

# Baptism 2026 event page — Stripe Payment Link URLs (hosted checkout, no webhook).
# Leave empty until the links are created in the Stripe Dashboard; buttons show a
# "not set up yet" message until both are set.
BAPTISM_2026_STRIPE_SHIRT_LINK=
BAPTISM_2026_STRIPE_DONATION_LINK=

# Square in-person giving (Phase 3 — leave empty until Square is connected)
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# SQUARE_WEBHOOK_SIGNATURE_KEY=
# SQUARE_ENV=sandbox

# PayPal + Venmo giving — leave empty until PayPal is connected.
# Venmo runs through PayPal's Checkout API (payment_source preference); there
# is no separate standalone Venmo API. Set PAYPAL_ENV=live to go live.
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_ENV=sandbox

# Google OAuth / OpenID Connect
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/google/callback

# Sign in with Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Store the PEM as a single env value; escaped \n sequences are supported.
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/apple/callback
